#!/bin/sh
# Generate bg/fg colors: theme cyan locally, hash-based over SSH.
# Override hue with WHEREAMI_COLOR_HUE=<0-359>.

set -e

string_to_hue() {
    str="$1"
    hash=0
    i=1
    while [ $i -le ${#str} ]; do
        char=$(printf '%s' "$str" | cut -c$i)
        val=$(printf '%d' "'$char")
        hash=$(( (hash * 31 + val) % 2147483647 ))
        i=$((i + 1))
    done
    echo $(( hash % 360 ))
}

hsl_to_hex() {
    python3 <<EOF
import colorsys
h, s, l = $1 / 360.0, $2 / 100.0, $3 / 100.0
r, g, b = colorsys.hls_to_rgb(h, l, s)
print('%02x%02x%02x' % (int(r * 255), int(g * 255), int(b * 255)))
EOF
}

hsl_to_256() {
    python3 <<EOF
import colorsys
h, s, l = $1 / 360.0, $2 / 100.0, $3 / 100.0
r, g, b = [int(x * 255) for x in colorsys.hls_to_rgb(h, l, s)]
# 6x6x6 color cube (indices 16-231)
cube = [0, 95, 135, 175, 215, 255]
ci = [min(range(6), key=lambda i: abs(v - cube[i])) for v in (r, g, b)]
cube_idx = 16 + 36 * ci[0] + 6 * ci[1] + ci[2]
cube_dist = sum((v - cube[i]) ** 2 for v, i in zip((r, g, b), ci))
# Grayscale ramp (indices 232-255)
gray = round((r + g + b) / 3)
gi = min(max(round((gray - 8) / 10), 0), 23)
gray_val = 8 + 10 * gi
gray_dist = sum((v - gray_val) ** 2 for v in (r, g, b))
print(232 + gi if gray_dist < cube_dist else cube_idx)
EOF
}

color_main() {
    convert=hsl_to_hex
    if [ "$1" = "--256" ]; then
        convert=hsl_to_256
        shift
    fi

    if [ -n "$WHEREAMI_COLOR_HUE" ]; then
        hue="$WHEREAMI_COLOR_HUE"
        bg_color=$($convert "$hue" 21 46)
        fg_color=$($convert "$hue" 2 73)
    elif [ -n "$SSH_TTY" ] || [ -n "$SSH_CONNECTION" ]; then
        WHEREAMI_BIN="${WHEREAMI_BIN:-$HOME/.local/bin/whereami}"
        if [ -x "$WHEREAMI_BIN" ]; then
            identifier=$("$WHEREAMI_BIN" -n 2>/dev/null || echo "unknown")
        else
            identifier="unknown"
        fi
        hue=$(string_to_hue "$identifier")
        bg_color=$($convert "$hue" 60 25)
        fg_color=$($convert "$hue" 10 90)
    else
        case "$convert" in
            hsl_to_256) bg_color=14;     fg_color=7      ;;
            *)          bg_color=2e706d; fg_color=b9bcba ;;
        esac
    fi

    case "${1:-bg}" in
        bg)   echo "$bg_color" ;;
        fg)   echo "$fg_color" ;;
        both) echo "bg=$bg_color fg=$fg_color" ;;
        *)    echo "$bg_color" ;;
    esac
}

if [ "${WHEREAMI_COLOR_SOURCE_ONLY:-0}" != "1" ]; then
    color_main "$@"
fi
