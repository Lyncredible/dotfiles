#!/bin/sh
# Generate bg/fg colors from machine identity by hashing to an HSL hue.

set -e

string_to_hue() {
    str="$1"
    hash=0
    i=1
    while [ $i -le ${#str} ]; do
        char=$(printf '%s' "$str" | cut -c$i)
        val=$(printf '%d' "'$char")
        hash=$(( (hash * 31 + val) % 2147483647 ))
        i=$((i + 1))
    done
    echo $(( hash % 360 ))
}

hsl_to_hex() {
    python3 <<EOF
import colorsys
h, s, l = $1 / 360.0, $2 / 100.0, $3 / 100.0
r, g, b = colorsys.hls_to_rgb(h, l, s)
print('%02x%02x%02x' % (int(r * 255), int(g * 255), int(b * 255)))
EOF
}

WHEREAMI_BIN="${HOME}/.local/bin/whereami"
if [ -x "$WHEREAMI_BIN" ]; then
    identifier=$("$WHEREAMI_BIN" -n 2>/dev/null || echo "unknown")
else
    identifier="unknown"
fi

hue=$(string_to_hue "$identifier")
bg_color=$(hsl_to_hex "$hue" 60 25)
fg_color=$(hsl_to_hex "$hue" 10 90)

case "${1:-bg}" in
    bg)   echo "$bg_color" ;;
    fg)   echo "$fg_color" ;;
    both) echo "bg=$bg_color fg=$fg_color" ;;
    *)    echo "$bg_color" ;;
esac
