adjust-cell-width = 0
cursor-click-to-move = true
cursor-style = block
font-family = MesloLGM Nerd Font
font-size = 12
font-thicken = true
adjust-cell-width = 0
shell-integration-features = no-cursor, ssh-terminfo
macos-titlebar-style = tabs
theme = Dimmed Monokai

# Bells
bell-features = no-audio

# Tab navigation
keybind = cmd+arrow_left=previous_tab
keybind = cmd+arrow_right=next_tab

# Quick terminal
keybind = ctrl+grave_accent=toggle_quick_terminal

# Tmux window switching (prefix = Ctrl+B = \x02)
keybind = cmd+n=text:\x02n
keybind = cmd+p=text:\x02p
keybind = cmd+1=text:\x021
keybind = cmd+2=text:\x022
keybind = cmd+3=text:\x023
keybind = cmd+4=text:\x024
keybind = cmd+5=text:\x025
keybind = cmd+6=text:\x026
keybind = cmd+7=text:\x027
keybind = cmd+8=text:\x028
keybind = cmd+9=text:\x029
keybind = cmd+0=text:\x020
